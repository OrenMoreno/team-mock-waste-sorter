<launch>
    <!-- Load parameters from YAML file -->
    <rosparam file="$(find vision_node)/config/vision_node_params.yaml" command="load" />

    <!-- Start the vision_node -->
    <node pkg="vision_node" type="vision_node.py" name="vision_node" output="screen">
        <param name="confidence_threshold" value="0.65" />
        <param name="model_path" value="$(find vision_node)/models/model.onnx" />
        <param name="input_width" value="640" />
        <param name="input_height" value="640" />
    </node>
</launch>